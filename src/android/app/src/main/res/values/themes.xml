<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- NoActionBar variant — required when using a custom Toolbar in the layout.
         DarkActionBar would provide a second action bar and crash with IllegalStateException. -->
    <style name="Theme.DermAI" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
        <item name="colorPrimary">@color/accent</item>
        <item name="colorPrimaryVariant">@color/accent_dim</item>
        <item name="colorOnPrimary">@color/bg_primary</item>
        <item name="colorSurface">@color/bg_surface</item>
        <item name="android:windowBackground">@color/bg_primary</item>
        <item name="android:statusBarColor">@color/bg_surface</item>
        <item name="android:navigationBarColor">@color/bg_surface</item>
    </style>
</resources>