<?xml version="1.0" encoding="utf-8"?>
<!--
  activity_main.xml
  ==================
  Layout for the main chat screen.
  Structure (top to bottom):
    - Toolbar (DermAI title + pulse indicator)
    - Classification badge (hidden until image analyzed)
    - RecyclerView (chat messages)
    - Streaming progress indicator
    - Image preview strip (hidden until image selected)
    - Input row: gallery | camera | text field | send
-->

<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_primary">

    <!-- Toolbar -->
    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/bg_surface"
        android:elevation="4dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_gravity="center_vertical">

            <View
                android:layout_width="8dp"
                android:layout_height="8dp"
                android:background="@drawable/pulse_dot"
                android:layout_marginEnd="10dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="DERMAI"
                android:textColor="@color/accent"
                android:textSize="14sp"
                android:letterSpacing="0.12"
                android:fontFamily="monospace" />
        </LinearLayout>
    </androidx.appcompat.widget.Toolbar>

    <!-- Classification badge -->
    <LinearLayout
        android:id="@+id/classificationBadge"
        android:layout_width="match_parent"
        android:layout_height="36dp"
        android:orientation="horizontal"
        android:gravity="center"
        android:visibility="gone"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        app:layout_constraintTop_toBottomOf="@id/toolbar"
        app:layout_constraintStart_toStartOf="parent">

        <TextView
            android:id="@+id/tvClassification"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/bg_primary"
            android:textSize="11sp"
            android:fontFamily="monospace"
            android:letterSpacing="0.08" />
    </LinearLayout>

    <!-- Chat RecyclerView -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerChat"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:padding="12dp"
        android:clipToPadding="false"
        android:scrollbars="vertical"
        app:layout_constraintTop_toBottomOf="@id/classificationBadge"
        app:layout_constraintBottom_toTopOf="@id/progressStreaming"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Streaming indicator -->
    <ProgressBar
        android:id="@+id/progressStreaming"
        style="@style/Widget.AppCompat.ProgressBar.Horizontal"
        android:layout_width="match_parent"
        android:layout_height="2dp"
        android:indeterminate="true"
        android:visibility="gone"
        android:indeterminateTint="@color/accent"
        app:layout_constraintBottom_toTopOf="@id/imagePreviewContainer"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- Image preview strip -->
    <LinearLayout
        android:id="@+id/imagePreviewContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:visibility="gone"
        android:padding="8dp"
        android:background="@color/bg_surface"
        android:gravity="center_vertical"
        app:layout_constraintBottom_toTopOf="@id/inputRow"
        app:layout_constraintStart_toStartOf="parent">

        <ImageView
            android:id="@+id/ivImagePreview"
            android:layout_width="52dp"
            android:layout_height="52dp"
            android:scaleType="centerCrop"
            android:background="@drawable/rounded_corners" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Image ready to send"
            android:textColor="@color/accent"
            android:textSize="12sp"
            android:fontFamily="monospace"
            android:layout_marginStart="10dp" />

        <ImageButton
            android:id="@+id/btnRemoveImage"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@android:drawable/ic_menu_close_clear_cancel"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:tint="@color/malignant" />
    </LinearLayout>

    <!-- Input row -->
    <LinearLayout
        android:id="@+id/inputRow"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="10dp"
        android:background="@color/bg_surface"
        android:gravity="center_vertical"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <!-- Gallery button -->
        <ImageButton
            android:id="@+id/btnGallery"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@android:drawable/ic_menu_gallery"
            android:background="@drawable/icon_btn_bg"
            android:tint="@color/text_dim"
            android:layout_marginEnd="6dp" />

        <!-- Camera button -->
        <ImageButton
            android:id="@+id/btnCamera"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@android:drawable/ic_menu_camera"
            android:background="@drawable/icon_btn_bg"
            android:tint="@color/text_dim"
            android:layout_marginEnd="6dp" />

        <!-- Text input — hint color set in MainActivity.kt -->
        <EditText
            android:id="@+id/etMessage"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:background="@drawable/input_bg"
            android:padding="10dp"
            android:hint="Describe your concern…"
            android:textColor="@color/text_primary"
            android:textSize="13sp"
            android:fontFamily="monospace"
            android:maxLines="4"
            android:inputType="textMultiLine"
            android:layout_marginEnd="6dp" />

        <!-- Send button -->
        <Button
            android:id="@+id/btnSend"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:text="SEND"
            android:textSize="11sp"
            android:letterSpacing="0.08"
            android:fontFamily="monospace"
            android:backgroundTint="@color/accent"
            android:textColor="@color/bg_primary" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
